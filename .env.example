APP_NAME=NautiSecure
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_FRONTEND_URL=http://localhost
APP_EMAIL_VERIFICATION_PATH=/verify-email
PARTNER_AGREEMENT_VERSION=v1
PARTNER_AGREEMENT_PATH=resources/legal/partner_agreement_v1.txt

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nautisecure
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

SIGNHOST_BASE_URL=https://api.signhost.com/api/
SIGNHOST_APP_KEY=
SIGNHOST_USER_TOKEN=
SIGNHOST_SHARED_SECRET=
SIGNHOST_WEBHOOK_AUTH=

MOLLIE_BASE_URL=https://api.mollie.com/v2
MOLLIE_API_KEY=
MOLLIE_API_KEY_TEST=
MOLLIE_API_KEY_LIVE=

# Sentry
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_SEND_PII=true
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_WEBHOOK_SECRET=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Frontend Sentry (Vite)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=

# Error AI
ERROR_AI_PROVIDER=gemini
ERROR_AI_MODEL=gemini-2.5-flash-lite
REPORT_ISSUE_RATE_LIMIT=3
REPORT_ISSUE_MAX_FILE_KB=10240
GEMINI_API_KEY=
OPENAI_API_KEY=

# Harbor Widget Monitoring
HARBOR_WIDGET_CTR_BENCHMARK=10
HARBOR_WIDGET_AI_PROVIDER=gemini
HARBOR_WIDGET_AI_MODEL=gemini-2.5-flash-lite
HARBOR_WIDGET_SCREENSHOT_TIMEOUT=45000
HARBOR_WIDGET_SCREENSHOT_WAIT_MS=3000
HARBOR_ATTRIBUTION_TTL_DAYS=30

# GA4 (Measurement + Data API)
GA4_PROPERTY_ID=
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY=
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
GA4_DATA_CACHE_TTL=3600
GA4_DIMENSION_HARBOR_ID=customEvent:harbor_id

# Yext Social Posting
YEXT_API_KEY=
YEXT_ACCOUNT_ID=
YEXT_ENTITY_ID=
YEXT_API_BASE=https://api.yextapis.com
YEXT_API_VERSION=20240101
YEXT_USE_PUBLISHER_TARGETS=true
YEXT_USE_VIDEO_UPLOAD=false
YEXT_VIDEO_PUBLISHERS=facebook,instagram
YEXT_ANALYTICS_ENDPOINT=

# Video Automation
VIDEO_AUTOMATION_ENABLED=true
VIDEO_AUTOMATION_ON_CREATE=true
VIDEO_AUTOMATION_ON_PUBLISH=true
VIDEO_AUTOMATION_PUBLISH_STATUSES=active,for sale,for bid,published
VIDEO_AUTOMATION_MIN_IMAGES=8
VIDEO_AUTOMATION_MAX_IMAGES=15
VIDEO_AUTOMATION_SECONDS_PER_IMAGE=2
VIDEO_AUTOMATION_FPS=30
VIDEO_AUTOMATION_RESOLUTION=1080x1920
VIDEO_AUTOMATION_CTA_TEXT=View full specs on NauticSecure.com
VIDEO_AUTOMATION_TEMPLATE=vertical_slideshow_v1
VIDEO_AUTOMATION_AUTO_SCHEDULE=true
VIDEO_AUTOMATION_SCHEDULE_TIME=10:30
VIDEO_AUTOMATION_SKIP_WEEKENDS=false
VIDEO_AUTOMATION_PUBLISHERS=facebook,instagram,google,linkedin,apple
VIDEO_AUTOMATION_UTM_SOURCE=yext
VIDEO_AUTOMATION_UTM_MEDIUM=social
VIDEO_AUTOMATION_UTM_CAMPAIGN=boat_video
FFMPEG_FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf

# Pinecone (FAQ Search)
PINECONE_API_KEY=
PINECONE_HOST=
PINECONE_INDEX=
PINECONE_FAQ_NAMESPACE=faq

# FAQ AI + Embeddings
FAQ_AI_PROVIDER=openai
FAQ_AI_MODEL=gpt-4o-mini
FAQ_EMBED_PROVIDER=openai
FAQ_EMBED_MODEL=text-embedding-3-small
FAQ_LONG_DESCRIPTION_MIN_WORDS=120
FAQ_LONG_DESCRIPTION_MAX_WORDS=220
FAQ_GENERATION_BATCH_SIZE=50
FAQ_INDEX_INCLUDE_LONG_DESCRIPTION=true
FAQ_REINDEX_ON_LONG_DESCRIPTION=false

# Chat / Unified Inbox
CHAT_RATE_LIMIT_PER_MINUTE=30
CHAT_ATTACHMENT_ALLOWLIST=image/png,image/jpeg,image/webp,application/pdf
CHAT_ATTACHMENT_MAX_SIZE=15728640
CHAT_FIRST_RESPONSE_MINUTES=30
CHAT_ESCALATE_TO_HARBOR_ID=1
CHAT_BUSINESS_HOURS_START=09:00
CHAT_BUSINESS_HOURS_END=17:00
CHAT_BUSINESS_TZ=Europe/Amsterdam
BOOKING_BUSINESS_TZ=Europe/Amsterdam
CHAT_ADAPTER_SECRET=
CHAT_AI_PROVIDER=openai
CHAT_AI_MODEL=gpt-4o-mini
CHAT_AI_USE_LLM=false
CHAT_AI_HIGH_CONF=0.82
CHAT_AI_MED_CONF=0.65
PINECONE_CHAT_FAQ_NAMESPACE=chat_faq
CHAT_OCR_ENABLED=false

# Email Verification Security
SECURITY_EMAIL_VERIFICATION_TTL_MINUTES=15
SECURITY_EMAIL_VERIFICATION_MAX_SEND=5
SECURITY_EMAIL_VERIFICATION_SEND_WINDOW=10
SECURITY_EMAIL_VERIFICATION_MAX_VERIFY=5
SECURITY_EMAIL_VERIFICATION_VERIFY_WINDOW=10
SECURITY_EMAIL_VERIFICATION_MAX_ATTEMPTS=5
SECURITY_EMAIL_VERIFICATION_LOCK_MINUTES=15
